# DevAI Copilot Environment Variables

# 1. Google Gemini API Key (Required for Cloud or Hybrid mode)
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# 2. Gemini Model Configuration
# Default is gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash

# 3. Local Ollama Model Configuration (Required for Local or Hybrid mode)
# Ensure Ollama is running and the model is pulled (e.g., ollama pull llama3)
OLLAMA_MODEL=llama3

# 4. DevAI Context Path (Optional)
# The directory DevAI should analyze and operate in. Defaults to current working directory.
# DEVAI_CONTEXT_PATH=/path/to/your/project
